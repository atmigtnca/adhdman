APP_NAME=ADHDman
APP_ENV=development
DATABASE_PATH=./data/adhdman.sqlite

# OpenRouter LLM provider (Phase 2). Leave OPENROUTER_API_KEY empty to disable
# the LLM stage; the pipeline still falls back to the inbox so nothing is dropped.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=inclusionai/ring-2.6-1t
LLM_TIMEOUT_SECONDS=8.0

# Phase 2 classification settings.
# RULES_ACCEPT_THRESHOLD: rules-pass confidence at/above this short-circuits the LLM.
# CLASSIFY_ENABLED: kill switch; when false every capture lands in the inbox.
RULES_ACCEPT_THRESHOLD=0.85
CLASSIFY_ENABLED=true

# Phase 3 resolver, search, and undo settings.
# LOCAL_TIMEZONE: IANA tz used by the datetime resolver when callers omit one.
# SEARCH_MAX_CANDIDATES: maximum candidates returned by /search.
# SEARCH_AMBIGUITY_THRESHOLD: minimum score gap between #1 and #2 below which
#   the server treats the match as ambiguous.
# UNDO_ENABLED: kill switch for the undo endpoints.
LOCAL_TIMEZONE=UTC
SEARCH_MAX_CANDIDATES=5
SEARCH_AMBIGUITY_THRESHOLD=0.15
UNDO_ENABLED=true

# Phase 4 TUI settings. The TUI defaults to the loopback backend and refuses
# non-loopback hosts unless ADHDMAN_ALLOW_REMOTE=1 (SSH-tunnel escape hatch).
# ADHDMAN_TIMEZONE overrides LOCAL_TIMEZONE for /resolve calls from the TUI.
ADHDMAN_BASE_URL=http://127.0.0.1:8000
ADHDMAN_TIMEZONE=
ADHDMAN_ALLOW_REMOTE=0
