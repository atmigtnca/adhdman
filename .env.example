APP_NAME=ADHDman
APP_ENV=development
DATABASE_PATH=./data/adhdman.sqlite

# OpenRouter LLM provider (Phase 2). Leave OPENROUTER_API_KEY empty to disable
# the LLM stage; the pipeline still falls back to the inbox so nothing is dropped.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=inclusionai/ring-2.6-1t:free
LLM_TIMEOUT_SECONDS=8.0

# Phase 2 classification settings.
# RULES_ACCEPT_THRESHOLD: rules-pass confidence at/above this short-circuits the LLM.
# CLASSIFY_ENABLED: kill switch; when false every capture lands in the inbox.
RULES_ACCEPT_THRESHOLD=0.85
CLASSIFY_ENABLED=true
